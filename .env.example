# ── Memory Backend ───────────────────────────────────────────────
# Options: sqlite | postgres
MEMORY_BACKEND=sqlite
SQLITE_DB_PATH=agentic_memory.db
POSTGRES_DSN=postgresql://postgres:postgres@localhost:5432/agentic_memory

# ── LLM Provider (Auto-Critic) ──────────────────────────────────
# Options: deterministic | groq | anthropic | openai
# When set to groq/anthropic/openai, the Critic LLM automatically
# evaluates each turn and extracts semantic facts. When set to
# deterministic, heuristic evaluation is used instead.
LLM_PROVIDER=deterministic
GROQ_API_KEY=
GROQ_BASE_URL=
# Actor/Critic model names (used by the standalone demo loop)
ACTOR_MODEL=llama3-8b-8192
CRITIC_MODEL=llama3-70b-8192
ANTHROPIC_API_KEY=
ANTHROPIC_ACTOR_MODEL=claude-sonnet-4-5
ANTHROPIC_CRITIC_MODEL=claude-opus-4-5
OPENAI_API_KEY=
OPENAI_BASE_URL=
OPENAI_ACTOR_MODEL=gpt-4o-mini
OPENAI_CRITIC_MODEL=gpt-4o

# ── MCP Transport ───────────────────────────────────────────────
# stdio: used by Claude Code (default)
# http:  runs a sidecar HTTP server for Codex and other clients
MCP_TRANSPORT=stdio
MCP_HTTP_PORT=8001

# ── Embeddings ──────────────────────────────────────────────────
# sentence-transformer: 384-dim vectors (best quality, requires torch)
# hash: 256-dim deterministic vectors (zero dependencies, fast startup)
EMBEDDING_BACKEND=sentence-transformer
EMBEDDING_MODEL_NAME=sentence-transformers/all-MiniLM-L6-v2
HASH_EMBEDDING_DIMENSIONS=256

# ── Memory Tuning ───────────────────────────────────────────────
MEMORY_WINDOW_TURNS=10
SEMANTIC_DEDUP_THRESHOLD=0.92
SEMANTIC_MEMORY_TTL_DAYS=180
FAILURE_SIMILARITY_THRESHOLD=0.80

# ── Critic Tuning ──────────────────────────────────────────────
CRITIC_TIMEOUT_SECONDS=8
CRITIC_SELF_CONSISTENCY_SAMPLES=3
CRITIC_SELF_CONSISTENCY_TEMPERATURE=0.4

# ── Brave Search (optional tool) ───────────────────────────────
BRAVE_SEARCH_API_KEY=
BRAVE_SEARCH_ENDPOINT=https://api.search.brave.com/res/v1/web/search
BRAVE_SEARCH_COUNTRY=us
BRAVE_SEARCH_LANG=en
BRAVE_SEARCH_COUNT=5
BRAVE_SEARCH_TIMEOUT_SECONDS=10

# ── Misc ────────────────────────────────────────────────────────
LOG_LEVEL=INFO
TOOL_WORKSPACE_ROOT=.
