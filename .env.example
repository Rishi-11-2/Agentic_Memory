# ── Memory Backend ───────────────────────────────────────────────
# Options: sqlite | postgres
# sqlite  → local .db file, client-side vector search, zero cloud deps
# postgres → local/remote PostgreSQL + pgvector, server-side vector search
MEMORY_BACKEND=sqlite
SQLITE_DB_PATH=agentic_memory.db
POSTGRES_DSN=postgresql://postgres:postgres@localhost:5432/agentic_memory

# ── LLM Provider ────────────────────────────────────────────────
# Options: deterministic | groq | anthropic | openai
# deterministic → offline local mode, no API calls
# groq → Groq Cloud API (requires GROQ_API_KEY)
# anthropic → Anthropic Claude API (requires ANTHROPIC_API_KEY)
# openai → OpenAI or OpenAI-compatible API (requires OPENAI_API_KEY)
LLM_PROVIDER=deterministic
GROQ_API_KEY=
GROQ_BASE_URL=
ACTOR_MODEL=llama3-8b-8192
CRITIC_MODEL=llama3-70b-8192
# Required when LLM_PROVIDER=anthropic.
ANTHROPIC_API_KEY=
ANTHROPIC_ACTOR_MODEL=claude-sonnet-4-5
ANTHROPIC_CRITIC_MODEL=claude-opus-4-5
# Required when LLM_PROVIDER=openai; OPENAI_BASE_URL is optional for Ollama, LM Studio, or Azure-compatible endpoints.
OPENAI_API_KEY=
OPENAI_BASE_URL=
OPENAI_ACTOR_MODEL=gpt-4o-mini
OPENAI_CRITIC_MODEL=gpt-4o

# ── MCP (Claude Code / Codex tool integration) ───────────────────
# stdio is used by Claude Code; http runs a sidecar server on MCP_HTTP_PORT.
MCP_TRANSPORT=stdio
MCP_HTTP_PORT=8001

# ── Brave Search (optional) ─────────────────────────────────────
BRAVE_SEARCH_API_KEY=
BRAVE_SEARCH_ENDPOINT=https://api.search.brave.com/res/v1/web/search
BRAVE_SEARCH_COUNTRY=us
BRAVE_SEARCH_LANG=en
BRAVE_SEARCH_COUNT=5
BRAVE_SEARCH_TIMEOUT_SECONDS=10

# ── Embeddings ──────────────────────────────────────────────────
# Options: sentence-transformer | hash
# sentence-transformer → 384-dim vectors (requires sentence-transformers)
# hash → 256-dim deterministic vectors (zero dependencies)
EMBEDDING_BACKEND=sentence-transformer
EMBEDDING_MODEL_NAME=sentence-transformers/all-MiniLM-L6-v2
HASH_EMBEDDING_DIMENSIONS=256

# ── Memory Tuning ───────────────────────────────────────────────
MEMORY_WINDOW_TURNS=10
SEMANTIC_DEDUP_THRESHOLD=0.92
# Semantic facts not confirmed within this many days are excluded from retrieval; 0 disables TTL.
SEMANTIC_MEMORY_TTL_DAYS=180
FAILURE_SIMILARITY_THRESHOLD=0.80

# ── Reliability and Security ────────────────────────────────────
# Critic timeout never blocks the user; consolidation is skipped on timeout.
CRITIC_TIMEOUT_SECONDS=8
# High-stakes turns use majority-vote Critic self-consistency with this sample count.
CRITIC_SELF_CONSISTENCY_SAMPLES=3
CRITIC_SELF_CONSISTENCY_TEMPERATURE=0.4


LOG_LEVEL=INFO

# ── Tool Settings ───────────────────────────────────────────────
# Root directory for file_search and document_search (absolute path or relative to cwd).
TOOL_WORKSPACE_ROOT=.
